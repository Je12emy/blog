---
import BaseLayout from "../layouts/BaseLayout.astro";
import GradientText from "../components/GradientText.astro";
import GradientButton from "../components/GradientButton.astro";
import { Icon } from "astro-icon";
---

<BaseLayout class="flex flex-col items-center">
	<div class="mt-14 h-screen flex flex-col space-y-6 items-center break-words">
		<h1 class="text-6xl md:text-8xl text-gray-50 font-open-sans font-bold text-center leading-tight">
			Hi! I'm <GradientText element="span" text="Je12emy" />
		</h1>
		<p class="font-nunito text-3xl md:text-5xl text-gray-50 text-left leading-normal md:leading-relaxed">
			Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do
			eiusmod tempor incididunt ut labore et dolore magna aliqua.
		</p>
		<div class="w-full grid grid-rows-2 gap-y-4 md:gap-y-0 grid-cols-1 md:grid-rows-1 md:grid-cols-2 justify-items-center md:justify-items-start">
			<GradientButton class="" text="Contact me"/>
			<Icon class="text-gray-50 h-16 w-16 cursor-pointer" name="akar-icons:circle-chevron-down-fill"/>
		</div>
	</div>
</BaseLayout>
