---
import BaseLayout from "../layouts/BaseLayout.astro";
import GradientText from "../components/GradientText.astro";
import GradientButton from "../components/GradientButton.astro";
import { Icon } from "astro-icon";
---

<BaseLayout class="flex flex-col items-center">
	<article
		class="h-screen flex flex-col space-y-12 items-center justify-center break-words"
	>
		<h1
			class="text-6xl md:text-9xl text-gray-50 font-open-sans font-bold text-center leading-tight"
		>
			Hi! I'm <GradientText element="span" text="Je12emy" />
		</h1>
		<p
			class="font-nunito text-3xl md:text-6xl text-gray-50 text-left leading-normal md:leading-relaxed"
		>
			Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do
			eiusmod tempor incididunt ut labore et dolore magna aliqua.
		</p>
		<div
			class="w-full grid grid-rows-2 gap-y-4 md:gap-y-0 grid-cols-1 md:grid-rows-1 md:grid-cols-2 justify-items-center md:justify-items-start"
		>
			<GradientButton class="" text="Contact me" />
			<Icon
				class="text-gray-50 h-16 w-16 md:h-20 md:w-20 cursor-pointer"
				name="akar-icons:circle-chevron-down-fill"
			/>
		</div>
	</article>
	<article class="flex flex-col space-y-12 justify-center items-start">
		<h1
			class="text-6xl md:text-9xl text-gray-50 font-open-sans font-bold text-center leading-tight"
		>
			<GradientText element="span" text="Who" /> am I?
		</h1>
		<section
			class="grid grid-rows-2 grid-cols-1 md:gap-x-12 md:grid-rows-1 md:grid-cols-2 justify-center items-center"
		>
			<p
				class="text-gray-50 text-2xl md:text-4xl font-nunito text-left leading-relaxed md:leading-relaxed"
			>
				Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do
				eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut
				enim ad minim veniam, quis nostrud exercitation ullamco laboris
				nisi ut aliquip ex ea commodo consequat. Duis aute irure dolor
				in reprehenderit in voluptate velit esse cillum dolore eu fugiat
				nulla pariatur. Excepteur sint occaecat cupidatat non proident,
				sunt in culpa qui officia deserunt mollit anim id est laborum.
			</p>
			<p
				class="text-gray-50 text-2xl md:text-4xl font-nunito text-left leading-relaxed md:leading-relaxed"
			>
				Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do
				eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut
				enim ad minim veniam, quis nostrud exercitation ullamco laboris
				nisi ut aliquip ex ea commodo consequat. Duis aute irure dolor
				in reprehenderit in voluptate velit esse cillum dolore eu fugiat
				nulla pariatur. Excepteur sint occaecat cupidatat non proident,
				sunt in culpa qui officia deserunt mollit anim id est laborum.
			</p>
		</section>
	</article>
</BaseLayout>
