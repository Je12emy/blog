---
import data from "../../public/experience.json";
---

{
    data.map((item) => (
        <section class="w-full grid grid-cols-1 md:grid-cols-2 grid-rows-2 md:grid-rows-1">
            <img src={`${item["showcase-image"]}`} />
            <div class="flex flex-col items-center justify-center text-gray-50 space-y-4">
                <h1 class="text-3xl">{item.title}</h1>
                <p>{item.description}</p>
            </div>
        </section>
    ))
}
